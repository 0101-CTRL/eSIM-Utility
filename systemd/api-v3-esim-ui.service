[Unit]
Description=APIv3 eSIM Test UI
After=network-online.target
Wants=network-online.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/api-v3-esim-ui
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/api-v3-esim-ui/venv/bin/uvicorn app:app --host 0.0.0.0 --port 8011
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
